# ─── Medical Imaging QA System — Environment Configuration ──────────────────
# Copy this file to ".env" and fill in your values before running the app.

# ─── Required ──────────────────────────────────────────────────────────────
# Groq API key for the AI agent chat and report generation.
# Get a FREE key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional — Server Settings ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ─── Optional — File Paths ─────────────────────────────────────────────────
# Path to the main inference model (relative to project root)
MODEL_PATH=models/best_pneumonia_model.keras

UPLOAD_DIR=uploads
OUTPUTS_DIR=outputs
REPORTS_DIR=reports

# ─── Optional — Auth ───────────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=pneumonia-qa-secret-key-change-in-production-2024

# How long (minutes) a doctor JWT token stays valid
TOKEN_EXPIRE_MINUTES=480

# ─── Optional — Database ───────────────────────────────────────────────────
DB_PATH=pneumonia_qa.db
